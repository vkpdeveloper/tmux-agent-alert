#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=lib/tmux.sh
. "$ROOT_DIR/lib/tmux.sh"
# shellcheck source=lib/notify.sh
. "$ROOT_DIR/lib/notify.sh"
# shellcheck source=config/default-rules.sh
. "$ROOT_DIR/config/default-rules.sh"

CUSTOM_RULES="${XDG_CONFIG_HOME:-$HOME/.config}/tmux-agent-alert/rules.sh"
if [ -f "$CUSTOM_RULES" ]; then
  # shellcheck source=/dev/null
  . "$CUSTOM_RULES"
fi

# shellcheck source=lib/detect.sh
. "$ROOT_DIR/lib/detect.sh"

STATE_DIR="${AGENT_ALERT_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/tmux-agent-alert}"
PID_FILE="$STATE_DIR/watch.pid"
LOG_FILE="$STATE_DIR/watch.log"

usage() {
  cat <<'EOF'
Usage: agent-alert <command>

Commands:
  start                 Start the watcher daemon
  stop                  Stop the watcher daemon
  restart               Restart the watcher daemon
  toggle                Start or stop the watcher daemon
  status                Print watcher status
  watch                 Run watcher loop in the foreground
  inspect-pane [pane]   Explain current detection for a pane
  request-permission    Request macOS notification permission for this terminal
  test-notify           Send a test notification
  clear-alert [pane]    Clear the tmux status marker for a visited pane
  pane-exited <pane>    Remove state for an exited pane
EOF
}

now_epoch() {
  date +%s
}

positive_integer_option() {
  local option="$1"
  local default_value="$2"
  local fallback_value="${3:-$2}"
  local value

  value="$(get_tmux_option "$option" "$default_value")"
  case "$value" in
    ''|*[!0-9]*)
      value="$default_value"
      ;;
    *)
      if [ "$value" -gt 0 ] 2>/dev/null; then
        printf '%s\n' "$value"
        return
      fi
      value="$default_value"
      ;;
  esac

  case "$value" in
    ''|*[!0-9]*)
      printf '%s\n' "$fallback_value"
      ;;
    *)
      if [ "$value" -gt 0 ] 2>/dev/null; then
        printf '%s\n' "$value"
      else
        printf '%s\n' "$fallback_value"
      fi
      ;;
  esac
}

nonnegative_integer_option() {
  local option="$1"
  local default_value="$2"
  local fallback_value="${3:-$2}"
  local value

  value="$(get_tmux_option "$option" "$default_value")"
  case "$value" in
    ''|*[!0-9]*)
      value="$default_value"
      ;;
    *)
      printf '%s\n' "$value"
      return
      ;;
  esac

  case "$value" in
    ''|*[!0-9]*)
      printf '%s\n' "$fallback_value"
      ;;
    *)
      printf '%s\n' "$value"
      ;;
  esac
}

poll_interval_option() {
  local value

  value="$(get_tmux_option "@agent-alert-poll-interval" "${AGENT_ALERT_POLL_INTERVAL:-1}")"
  if printf '%s\n' "$value" | awk '/^[0-9]+([.][0-9]+)?$/ && $1 > 0 { found = 1 } END { exit found ? 0 : 1 }'; then
    printf '%s\n' "$value"
  else
    printf '%s\n' "1"
  fi
}

ensure_state_dir() {
  mkdir -p "$STATE_DIR"
}

log_debug() {
  local enabled
  enabled="$(get_tmux_option "@agent-alert-debug" "${AGENT_ALERT_DEBUG:-off}")"
  is_enabled "$enabled" || return 0

  log_event "$*"
}

log_event() {
  ensure_state_dir
  printf '%s %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$*" >> "$LOG_FILE"
}

pid_alive() {
  local pid="${1:-}"
  [ -n "$pid" ] && kill -0 "$pid" >/dev/null 2>&1
}

watcher_pids() {
  local script="$ROOT_DIR/bin/agent-alert"
  local self="$$"

  ps -axo pid=,command= 2>/dev/null | awk -v script="$script" -v self="$self" '
    $1 != self && index($0, script " watch") {
      print $1
    }
  '
}

running_pid() {
  if [ -f "$PID_FILE" ]; then
    local pid
    pid="$(cat "$PID_FILE" 2>/dev/null || true)"
    if pid_alive "$pid"; then
      printf '%s\n' "$pid"
      return 0
    fi
  fi

  local discovered
  discovered="$(watcher_pids | head -1)"
  if [ -n "$discovered" ]; then
    printf '%s\n' "$discovered" > "$PID_FILE"
    printf '%s\n' "$discovered"
    return 0
  fi

  return 1
}

dedupe_watchers() {
  local keep="" pid pids

  pids="$(watcher_pids)"
  for pid in $pids; do
    if [ -z "$keep" ]; then
      keep="$pid"
      printf '%s\n' "$keep" > "$PID_FILE"
    else
      kill "$pid" >/dev/null 2>&1 || true
    fi
  done
}

state_file_for_pane() {
  local pane="$1"
  printf '%s/%s.state\n' "$STATE_DIR" "${pane#%}"
}

state_get() {
  local file="$1"
  local key="$2"
  local default_value="${3:-}"

  if [ ! -f "$file" ]; then
    printf '%s\n' "$default_value"
    return
  fi

  awk -F '\t' -v key="$key" -v default_value="$default_value" '
    $1 == key {
      sub(/^[^\t]*\t/, "")
      print
      found = 1
      exit
    }
    END {
      if (!found) {
        print default_value
      }
    }
  ' "$file" || printf '%s\n' "$default_value"
}

write_state() {
  local file="$1"
  shift
  local tmp="$file.tmp"

  : > "$tmp"
  while [ "$#" -gt 0 ]; do
    printf '%s\t%s\n' "$1" "$2" >> "$tmp"
    shift 2
  done

  mv "$tmp" "$file"
}

state_update_fields() {
  local file="$1"
  shift

  [ -f "$file" ] || return 0
  [ "$#" -gt 0 ] || return 0

  local tmp="$file.tmp"
  local updates="$file.updates.$$"

  : > "$updates"
  while [ "$#" -gt 0 ]; do
    printf '%s\t%s\n' "$1" "$2" >> "$updates"
    shift 2
  done

  if ! awk -F '\t' '
    NR == FNR {
      updates[$1] = $2
      order[++count] = $1
      next
    }
    {
      key = $1
      if (key in updates) {
        print key "\t" updates[key]
        seen[key] = 1
      } else {
        print
      }
    }
    END {
      for (i = 1; i <= count; i++) {
        key = order[i]
        if (!(key in seen)) {
          print key "\t" updates[key]
        }
      }
    }
  ' "$updates" "$file" > "$tmp"; then
    rm -f "$tmp" "$updates"
    return 0
  fi

  mv "$tmp" "$file" || {
    rm -f "$tmp" "$updates"
    return 0
  }
  rm -f "$updates"
}

capture_clean_pane() {
  local pane="$1"
  local capture_lines="$2"

  tmux capture-pane -p -t "$pane" -S "-$capture_lines" 2>/dev/null | clean_ansi
}

enabled_agents_option() {
  get_tmux_option "@agent-alert-agents" "${AGENT_ALERT_AGENTS:-$AGENT_ALERT_KNOWN_AGENTS}"
}

notify_title_for_state() {
  local agent="$1"
  local state="$2"
  local display_name
  local action

  display_name="$(agent_notification_name "$agent")"

  case "$state" in
    WAITING_FOR_PERMISSION)
      action="Asking Permission"
      ;;
    DONE_WAITING_FOR_NEXT_PROMPT)
      action="Completed"
      ;;
    SILENT_UNKNOWN)
      action="Silent"
      ;;
    *)
      action="Needs Attention"
      ;;
  esac

  printf '%s - %s\n' "$display_name" "$action"
}

agent_notification_name() {
  case "$1" in
    codex)
      printf '%s\n' "Codex"
      ;;
    claude)
      printf '%s\n' "Claude"
      ;;
    opencode)
      printf '%s\n' "OpenCode"
      ;;
    pi)
      printf '%s\n' "Pi"
      ;;
    *)
      printf '%s\n' "Agent"
      ;;
  esac
}

shorten_context() {
  local value="$1"
  local max_length="${2:-180}"

  value="$(printf '%s' "$value" | tr '\n' ' ' | sed 's/[[:space:]][[:space:]]*/ /g; s/^[[:space:]]*//; s/[[:space:]]*$//')"

  if [ "${#value}" -gt "$max_length" ]; then
    printf '%s...\n' "${value:0:max_length}"
  else
    printf '%s\n' "$value"
  fi
}

notify_message_for_pane() {
  local state="$2"
  local session="$3"
  local window_name="$4"
  local window_index="$5"
  local pane_index="$6"
  local pane="$7"
  local context="$9"
  local session_attached="${10:-}"
  local reason_label short_context location attach_label

  short_context="$(shorten_context "$context" 140)"
  location="$(notification_location_for_pane "$session" "$window_name" "$window_index" "$pane_index")"

  if [ "$session_attached" = "0" ]; then
    attach_label="detached"
  else
    attach_label="attached"
  fi

  case "$state" in
    WAITING_FOR_PERMISSION)
      reason_label="Needs your approval"
      ;;
    DONE_WAITING_FOR_NEXT_PROMPT)
      reason_label="Finished and ready for the next prompt"
      ;;
    SILENT_UNKNOWN)
      reason_label="Stopped producing output"
      ;;
    *)
      reason_label="State changed"
      ;;
  esac

  if [ -n "$short_context" ]; then
    printf '%s (%s, %s)\n%s: %s' "$location" "$pane" "$attach_label" "$reason_label" "$short_context"
  else
    printf '%s (%s, %s)\n%s' "$location" "$pane" "$attach_label" "$reason_label"
  fi
}

notification_subtitle_for_pane() {
  local session="$1"
  local window_name="$2"
  local window_index="$3"
  local pane_index="$4"
  local session_attached="${5:-}"
  local label

  if [ "$session_attached" = "0" ]; then
    label="detached"
  else
    label="attached"
  fi

  printf '%s (%s)\n' "$(notification_location_for_pane "$session" "$window_name" "$window_index" "$pane_index")" "$label"
}

pane_location() {
  local session="$1"
  local window_name="$2"
  local window_index="$3"
  local pane_index="$4"

  if [ -n "$window_name" ]; then
    printf '%s:%s.%s %s' "$session" "$window_index" "$pane_index" "$window_name"
  else
    printf '%s:%s.%s' "$session" "$window_index" "$pane_index"
  fi
}

notification_location_for_pane() {
  local session="$1"
  local window_name="$2"
  local window_index="$3"
  local pane_index="$4"

  if [ -n "$window_name" ]; then
    printf '%s:%s' "$session" "$window_name"
  else
    printf '%s:%s.%s' "$session" "$window_index" "$pane_index"
  fi
}

macos_sender_bundle_option() {
  get_tmux_option "@agent-alert-macos-sender-bundle" "${AGENT_ALERT_MACOS_SENDER_BUNDLE:-auto}"
}

notification_permission_marker_file() {
  local bundle_id="$1"
  local marker_key

  marker_key="$(printf '%s' "$bundle_id" | tr -c '[:alnum:]._' '_')"
  printf '%s\n' "$STATE_DIR/macos-permission-$marker_key.seen"
}

visual_alert_enabled() {
  local enabled
  enabled="$(get_tmux_option "@agent-alert-visual-alert" "${AGENT_ALERT_VISUAL_ALERT:-on}")"
  is_enabled "$enabled"
}

visual_alert_style_for_state() {
  local state="$1"

  case "$state" in
    WAITING_FOR_PERMISSION)
      printf '%s\n' "red"
      ;;
    DONE_WAITING_FOR_NEXT_PROMPT)
      printf '%s\n' "green"
      ;;
    *)
      printf '%s\n' "default"
      ;;
  esac
}

visual_alert_state_is_attention() {
  case "$1" in
    WAITING_FOR_PERMISSION|DONE_WAITING_FOR_NEXT_PROMPT)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

visual_alert_value_is_attention() {
  case "$1" in
    red|green)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

refresh_visual_alert_for_window() {
  local window_target="$1"
  local session window_index file file_session file_window file_visual style

  [ -n "$window_target" ] || return 0

  if ! visual_alert_enabled; then
    tmux set-window-option -qu -t "$window_target" "@agent-alert-attention" 2>/dev/null || true
    return 0
  fi

  session="${window_target%%:*}"
  window_index="${window_target#*:}"
  style=""

  for file in "$STATE_DIR"/*.state; do
    [ -f "$file" ] || continue

    file_session="$(state_get "$file" "session" "")"
    file_window="$(state_get "$file" "window_index" "")"
    [ "$file_session" = "$session" ] || continue
    [ "$file_window" = "$window_index" ] || continue

    file_visual="$(state_get "$file" "visual_alert" "default")"
    case "$file_visual" in
      red)
        style="red"
        break
        ;;
      green)
        [ -z "$style" ] && style="green"
        ;;
    esac
  done

  if [ -n "$style" ]; then
    tmux set-window-option -q -t "$window_target" "@agent-alert-attention" "$style" 2>/dev/null || true
  else
    tmux set-window-option -qu -t "$window_target" "@agent-alert-attention" 2>/dev/null || true
  fi
}

refresh_visual_alert_for_pane() {
  local pane="$1"
  local window_target

  [ -n "$pane" ] || return 0
  window_target="$(tmux display-message -p -t "$pane" '#{session_name}:#{window_index}' 2>/dev/null || true)"
  [ -n "$window_target" ] || return 0

  refresh_visual_alert_for_window "$window_target"
}

clear_visual_alert_for_pane() {
  local pane="$1"
  local file state visual_alert last_hash

  if [ -z "$pane" ]; then
    pane="$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)"
  fi

  [ -n "$pane" ] || return 0

  file="$(state_file_for_pane "$pane")"
  if [ -f "$file" ]; then
    state="$(state_get "$file" "state" "")"
    visual_alert="$(state_get "$file" "visual_alert" "default")"
    last_hash="$(state_get "$file" "last_hash" "")"

    if visual_alert_state_is_attention "$state" || visual_alert_value_is_attention "$visual_alert"; then
      state_update_fields "$file" \
        "visual_alert" "default" \
        "acknowledged_state" "$state" \
        "acknowledged_hash" "$last_hash"
    fi
  fi

  refresh_visual_alert_for_pane "$pane"
}

show_tmux_alert_fallback() {
  local title="$1"
  local pane="$2"
  local display_time

  display_time="$(get_tmux_option "@agent-alert-tmux-message-duration" "${AGENT_ALERT_TMUX_MESSAGE_DURATION:-3000}")"

  if [ "${display_time:-0}" -lt 3000 ] 2>/dev/null; then
    display_time="3000"
  fi

  tmux display-message -d "$display_time" -t "$pane" "$title" 2>/dev/null || tmux display-message -d "$display_time" "$title" 2>/dev/null || true
}

request_macos_permission() {
  local force="${1:-no}"
  local enabled backend bundle marker_file resolved_bundle native_bundle

  is_macos || return 0

  enabled="$(get_tmux_option "@agent-alert-request-macos-permission" "${AGENT_ALERT_REQUEST_MACOS_PERMISSION:-on}")"
  is_enabled "$enabled" || return 0

  backend="$(get_tmux_option "@agent-alert-backend" "${AGENT_ALERT_BACKEND:-auto}")"
  case "$backend" in
    auto|macos-native|macos-terminal)
      ;;
    *)
      return 0
      ;;
  esac

  ensure_state_dir

  case "$backend" in
    auto|macos-native)
      native_bundle="$(macos_native_notifier_bundle_id)"
      marker_file="$(notification_permission_marker_file "$native_bundle")"

      if [ "$force" = "yes" ] || [ ! -f "$marker_file" ]; then
        if macos_display_notification_from_native \
          "tmux-agent-alert" \
          "Notification permission check for $native_bundle" \
          "$STATE_DIR" \
          "permission setup" \
          "$(notification_permission_timeout)"; then
          printf '%s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" > "$marker_file"
          return 0
        fi
      else
        return 0
      fi
      ;;
  esac

  bundle="$(macos_sender_bundle_option)"
  resolved_bundle="$bundle"

  if [ "$bundle" = "auto" ] || [ -z "$bundle" ]; then
    resolved_bundle="$(macos_terminal_bundle_from_tmux_clients "$STATE_DIR" || true)"
  fi

  [ -n "$resolved_bundle" ] || return 0

  marker_file="$(notification_permission_marker_file "$resolved_bundle")"

  if [ "$force" != "yes" ] && [ -f "$marker_file" ]; then
    return 0
  fi

  if notify_user "tmux-agent-alert" "Notification permission check for $resolved_bundle" "macos-terminal" "" "$STATE_DIR" "$resolved_bundle" "permission setup"; then
    printf '%s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" > "$marker_file"
  fi
}

should_notify_transition() {
  local old_state="$1"
  local new_state="$2"
  local notify_unknown="$3"

  [ "$old_state" = "$new_state" ] && return 1

  case "$new_state" in
    WAITING_FOR_PERMISSION|DONE_WAITING_FOR_NEXT_PROMPT)
      return 0
      ;;
    SILENT_UNKNOWN)
      is_enabled "$notify_unknown" || return 1
      [ "$old_state" = "RUNNING" ] && return 0
      ;;
  esac

  return 1
}

state_notification_ignores_min_runtime() {
  case "$1" in
    WAITING_FOR_PERMISSION|DONE_WAITING_FOR_NEXT_PROMPT)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

check_pane() {
  local pane="$1"
  local session="$2"
  local window_name="$3"
  local window_index="$4"
  local pane_index="$5"
  local pane_pid="$6"
  local command="$7"
  local path="$8"
  local session_attached="$9"
  local inspect="${10:-no}"

  local silence_threshold capture_lines notify_unknown cooldown min_runtime backend webhook_url macos_sender_bundle enabled_agents
  silence_threshold="$(positive_integer_option "@agent-alert-silence-threshold" "${AGENT_ALERT_SILENCE_THRESHOLD:-3}" "3")"
  capture_lines="$(positive_integer_option "@agent-alert-capture-lines" "${AGENT_ALERT_CAPTURE_LINES:-200}" "200")"
  notify_unknown="$(get_tmux_option "@agent-alert-notify-silent-unknown" "${AGENT_ALERT_NOTIFY_SILENT_UNKNOWN:-off}")"
  cooldown="$(nonnegative_integer_option "@agent-alert-cooldown" "${AGENT_ALERT_COOLDOWN:-300}" "300")"
  min_runtime="$(nonnegative_integer_option "@agent-alert-min-runtime" "${AGENT_ALERT_MIN_RUNTIME:-8}" "8")"
  backend="$(get_tmux_option "@agent-alert-backend" "${AGENT_ALERT_BACKEND:-auto}")"
  webhook_url="$(get_tmux_option "@agent-alert-webhook-url" "${AGENT_ALERT_WEBHOOK_URL:-}")"
  macos_sender_bundle="$(macos_sender_bundle_option)"
  enabled_agents="$(enabled_agents_option)"

  local content analysis_text process_text agent hash file now old_hash old_last_changed old_state old_first_seen old_last_notified old_last_notified_at old_last_notified_hash old_acknowledged_state old_acknowledged_hash
  local silence_duration new_state reason context runtime can_notify title message subtitle location stored_visual_alert acknowledged_current_attention notification_key_changed

  content="$(capture_clean_pane "$pane" "$capture_lines" || true)"
  [ -n "$content" ] || return 0
  analysis_text="$(printf '%s\n' "$content" | tail -60)"

  process_text="$(process_tree_text "$pane_pid" || true)"
  agent="$(detect_agent "$command" "$process_text" "$content" "$enabled_agents" || true)"

  if [ -z "$agent" ]; then
    if [ "$inspect" = "yes" ]; then
      printf 'Pane: %s\nSession: %s\nWindow: %s.%s %s\nCommand: %s\nAgent: not detected\n' \
        "$pane" "$session" "$window_index" "$pane_index" "$window_name" "$command"
    fi
    return 0
  fi

  hash="$(printf '%s' "$content" | content_hash)"
  file="$(state_file_for_pane "$pane")"
  now="$(now_epoch)"

  old_hash="$(state_get "$file" "last_hash" "")"
  old_last_changed="$(state_get "$file" "last_changed_at" "$now")"
  old_state="$(state_get "$file" "state" "UNKNOWN")"
  old_first_seen="$(state_get "$file" "first_seen_at" "$now")"
  old_last_notified="$(state_get "$file" "last_notified_state" "")"
  old_last_notified_at="$(state_get "$file" "last_notified_at" "0")"
  old_last_notified_hash="$(state_get "$file" "last_notified_hash" "")"
  old_acknowledged_state="$(state_get "$file" "acknowledged_state" "")"
  old_acknowledged_hash="$(state_get "$file" "acknowledged_hash" "")"

  if [ -z "$old_hash" ]; then
    new_state="UNKNOWN"
    reason="first observation"
    old_last_changed="$now"
  elif [ "$hash" != "$old_hash" ]; then
    local detection candidate_state candidate_reason
    detection="$(detect_active_state "$agent" "$analysis_text")"
    candidate_state="${detection%%$'\t'*}"
    candidate_reason="${detection#*$'\t'}"

    case "$candidate_state" in
      WAITING_FOR_PERMISSION|DONE_WAITING_FOR_NEXT_PROMPT)
        new_state="$candidate_state"
        reason="$candidate_reason"
        ;;
      *)
        new_state="RUNNING"
        reason="pane output changed"
        ;;
    esac

    old_last_changed="$now"
    if [ "$new_state" = "RUNNING" ]; then
      old_last_notified=""
      old_last_notified_at="0"
      old_last_notified_hash=""
      old_acknowledged_state=""
      old_acknowledged_hash=""
    fi
  else
    silence_duration=$((now - old_last_changed))
    if [ "$silence_duration" -ge "$silence_threshold" ]; then
      local detection
      detection="$(detect_silent_state "$agent" "$analysis_text")"
      new_state="${detection%%$'\t'*}"
      reason="${detection#*$'\t'}"
    else
      new_state="$old_state"
      reason="silent for ${silence_duration}s, below threshold"
    fi
  fi

  silence_duration=$((now - old_last_changed))
  runtime=$((now - old_first_seen))
  context="$(printf '%s\n' "$content" | last_visible_line)"
  location="$(pane_location "$session" "$window_name" "$window_index" "$pane_index")"
  stored_visual_alert="$(visual_alert_style_for_state "$new_state")"
  acknowledged_current_attention="no"

  if visual_alert_state_is_attention "$new_state" && [ -n "$old_acknowledged_hash" ] && [ "$old_acknowledged_hash" = "$hash" ]; then
    acknowledged_current_attention="yes"
    stored_visual_alert="default"
  fi

  can_notify="no"
  if [ "$acknowledged_current_attention" != "yes" ] && visual_alert_state_is_attention "$new_state"; then
    notification_key_changed="no"
    if [ "$old_last_notified" != "$new_state" ] || [ "$old_last_notified_hash" != "$hash" ]; then
      notification_key_changed="yes"
    fi

    if [ "$notification_key_changed" = "yes" ] && { state_notification_ignores_min_runtime "$new_state" || [ "$runtime" -ge "$min_runtime" ]; }; then
      can_notify="yes"
    fi
  elif should_notify_transition "$old_state" "$new_state" "$notify_unknown"; then
    if [ "$old_last_notified" != "$new_state" ] && [ $((now - old_last_notified_at)) -ge "$cooldown" ] && [ "$old_last_notified_hash" != "$hash" ]; then
      if [ "$runtime" -ge "$min_runtime" ]; then
        can_notify="yes"
      fi
    fi
  fi

  if [ "$inspect" = "yes" ]; then
    cat <<EOF
Pane: $pane
Session: $session
Window: $window_index.$pane_index $window_name
Path: $path
Command: $command
Agent: $agent
State: $new_state
Previous state: $old_state
Silence: ${silence_duration}s
Runtime: ${runtime}s
Matched rule: $reason
Last line: $context
Notification title: $(notify_title_for_state "$agent" "$new_state" "$location")
Notification subtitle: $(notification_subtitle_for_pane "$session" "$window_name" "$window_index" "$pane_index" "$session_attached")
Visual alert: $(if visual_alert_enabled; then printf '%s' "$stored_visual_alert"; else printf 'off'; fi)
Last notified state: $old_last_notified
Last notified hash: $old_last_notified_hash
Acknowledged state: $old_acknowledged_state
Acknowledged hash: $old_acknowledged_hash
EOF
    return 0
  fi

  if [ "$can_notify" = "yes" ]; then
    title="$(notify_title_for_state "$agent" "$new_state" "$location")"
    subtitle="$(notification_subtitle_for_pane "$session" "$window_name" "$window_index" "$pane_index" "$session_attached")"
    message="$(notify_message_for_pane "$agent" "$new_state" "$session" "$window_name" "$window_index" "$pane_index" "$pane" "$path" "$context" "$session_attached")"
    if notify_user "$title" "$message" "$backend" "$webhook_url" "$STATE_DIR" "$macos_sender_bundle" "$subtitle"; then
      if [ "$new_state" = "WAITING_FOR_PERMISSION" ]; then
        show_tmux_alert_fallback "$title" "$pane"
      fi
    else
      show_tmux_alert_fallback "$title" "$pane"
    fi
    old_last_notified="$new_state"
    old_last_notified_at="$now"
    old_last_notified_hash="$hash"
    log_debug "notified pane=$pane agent=$agent state=$new_state reason=$reason"
  fi

  write_state "$file" \
    "pane" "$pane" \
    "agent" "$agent" \
    "session" "$session" \
    "window_name" "$window_name" \
    "window_index" "$window_index" \
    "pane_index" "$pane_index" \
    "session_attached" "$session_attached" \
    "visual_alert" "$stored_visual_alert" \
    "state" "$new_state" \
    "last_hash" "$hash" \
    "last_changed_at" "$old_last_changed" \
    "first_seen_at" "$old_first_seen" \
    "last_notified_state" "$old_last_notified" \
    "last_notified_at" "$old_last_notified_at" \
    "last_notified_hash" "$old_last_notified_hash" \
    "acknowledged_state" "$old_acknowledged_state" \
    "acknowledged_hash" "$old_acknowledged_hash" \
    "last_reason" "$reason" \
    "last_context" "$context"

  refresh_visual_alert_for_pane "$pane"
}

list_panes() {
  tmux list-panes -a -F '#{pane_id}|#{session_name}|#{window_name}|#{window_index}|#{pane_index}|#{pane_pid}|#{pane_current_command}|#{pane_current_path}|#{session_attached}'
}

watch_loop() {
  # The daemon should keep polling even if one pane, notification backend, or
  # tmux command has a transient failure.
  set +e

  ensure_state_dir
  echo "$$" > "$PID_FILE"
  log_debug "watcher started pid=$$"

  trap 'log_debug "watcher exiting pid=$$"; rm -f "$PID_FILE"; exit 0' INT TERM EXIT

  while true; do
    if ! tmux_has_session; then
      log_event "tmux server unavailable, exiting"
      exit 0
    fi

    local poll_interval
    poll_interval="$(poll_interval_option)"

    while IFS='|' read -r pane session window_name window_index pane_index pane_pid command path session_attached; do
      [ -n "$pane" ] || continue
      check_pane "$pane" "$session" "$window_name" "$window_index" "$pane_index" "$pane_pid" "$command" "$path" "$session_attached" "no" || true
    done < <(list_panes || true)

    sleep "$poll_interval"
  done
}

start_watcher() {
  ensure_state_dir
  request_macos_permission "no" || true
  dedupe_watchers

  if running_pid >/dev/null; then
    printf 'tmux-agent-alert already running (pid %s)\n' "$(running_pid)"
    return 0
  fi

  if ! tmux_has_session; then
    printf 'tmux-agent-alert cannot start: no tmux server found\n' >&2
    return 1
  fi

  nohup "$0" watch >> "$LOG_FILE" 2>&1 &
  echo "$!" > "$PID_FILE"
  printf 'tmux-agent-alert started (pid %s)\n' "$!"
}

stop_watcher() {
  local pid pids
  pid="$(running_pid || true)"

  if [ -z "$pid" ]; then
    rm -f "$PID_FILE"
    printf 'tmux-agent-alert is not running\n'
    return 0
  fi

  pids="$(watcher_pids)"
  if [ -n "$pids" ]; then
    # shellcheck disable=SC2086
    kill $pids >/dev/null 2>&1 || true
    local _wait
    for _wait in 1 2 3 4 5; do
      [ -z "$(watcher_pids)" ] && break
      sleep 0.2
    done
  else
    kill "$pid" >/dev/null 2>&1 || true
  fi
  rm -f "$PID_FILE"
  printf 'tmux-agent-alert stopped\n'
}

status_watcher() {
  local pid
  pid="$(running_pid || true)"

  if [ -n "$pid" ]; then
    printf 'tmux-agent-alert running (pid %s)\n' "$pid"
  else
    printf 'tmux-agent-alert stopped\n'
  fi

  printf 'State dir: %s\n' "$STATE_DIR"
  printf 'Agents: %s\n' "$(enabled_agents_option)"
  printf 'Sessions:\n'
  tmux list-sessions -F '  #{session_name}: #{session_windows} window(s), attached=#{session_attached}' 2>/dev/null || true

  if is_macos; then
    local bundle_id
    printf 'macOS native notifier: %s\n' "$(macos_native_notifier_status "$STATE_DIR")"
    bundle_id="$(macos_terminal_bundle_from_tmux_clients "$STATE_DIR" || true)"
    printf 'macOS terminal fallback sender bundle: %s\n' "${bundle_id:-not detected}"
  fi
}

inspect_pane() {
  local target="${1:-}"

  if [ -z "$target" ]; then
    target="$(tmux display-message -p '#{pane_id}')"
  fi

  local line
  line="$(tmux display-message -p -t "$target" '#{pane_id}|#{session_name}|#{window_name}|#{window_index}|#{pane_index}|#{pane_pid}|#{pane_current_command}|#{pane_current_path}|#{session_attached}')"

  IFS='|' read -r pane session window_name window_index pane_index pane_pid command path session_attached <<< "$line"
  check_pane "$pane" "$session" "$window_name" "$window_index" "$pane_index" "$pane_pid" "$command" "$path" "$session_attached" "yes"
}

test_notify() {
  local backend webhook_url macos_sender_bundle
  backend="$(get_tmux_option "@agent-alert-backend" "${AGENT_ALERT_BACKEND:-auto}")"
  webhook_url="$(get_tmux_option "@agent-alert-webhook-url" "${AGENT_ALERT_WEBHOOK_URL:-}")"
  macos_sender_bundle="$(macos_sender_bundle_option)"

  notify_user "tmux-agent-alert test" "Notifications are working." "$backend" "$webhook_url" "$STATE_DIR" "$macos_sender_bundle" "test notification"
}

clear_alert() {
  local pane="${1:-}"

  if [ -z "$pane" ]; then
    pane="$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)"
  fi

  [ -n "$pane" ] || return 0

  clear_visual_alert_for_pane "$pane"
  return 0
}

pane_exited() {
  local pane="${1:-}"
  local file session window_index

  [ -n "$pane" ] || return 0

  file="$(state_file_for_pane "$pane")"
  session="$(state_get "$file" "session" "")"
  window_index="$(state_get "$file" "window_index" "")"

  rm -f "$file"

  if [ -n "$session" ] && [ -n "$window_index" ]; then
    refresh_visual_alert_for_window "$session:$window_index"
  fi
}

main() {
  local command="${1:-}"
  shift || true

  case "$command" in
    start)
      start_watcher
      ;;
    stop)
      stop_watcher
      ;;
    restart)
      stop_watcher
      start_watcher
      ;;
    toggle)
      if running_pid >/dev/null; then
        stop_watcher
      else
        start_watcher
      fi
      ;;
    status)
      status_watcher
      ;;
    watch)
      watch_loop
      ;;
    inspect-pane)
      inspect_pane "${1:-}"
      ;;
    request-permission)
      request_macos_permission "yes"
      ;;
    test-notify)
      test_notify
      ;;
    clear-alert)
      clear_alert "${1:-}"
      ;;
    pane-exited)
      pane_exited "${1:-}"
      ;;
    ""|help|--help|-h)
      usage
      ;;
    *)
      printf 'Unknown command: %s\n\n' "$command" >&2
      usage >&2
      return 1
      ;;
  esac
}

main "$@"
